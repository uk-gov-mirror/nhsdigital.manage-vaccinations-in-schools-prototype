{% set summary = patientProgramme.scheduleSummary %}

{% call card({
  heading: __("patientProgramme.vaccinationRecord.label"),
  headingLevel: 3
}) %}
  <p class="nhsuk-body">
    {{ __mf("patientProgramme.vaccinationRecord.dosesComplete", {
      complete: summary.dosesComplete,
      needed: summary.dosesNeeded
    }) }}
  </p>

  {% set rows = [] %}

  {% for ignored in summary.ignoredDoses %}
    {% set ignoredLabelHtml %}
      <span>
        {{- tag({
          text: __("patientProgramme.vaccinationRecord.ignored.label"),
          classes: "nhsuk-tag--grey"
        }) -}}
        <br>
        <span class="nhsuk-u-secondary-text-colour nhsuk-u-font-size-16">{{ ignored.reason }}</span>
      </span>
    {% endset %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        html: ignoredLabelHtml
      },
      {
        header: __("vaccination.createdAt.label"),
        text: ignored.vaccination.formatted.createdAt_date
      }
    ]) %}
  {% endfor %}

  {% for valid in summary.validDoses %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        text: __mf("patientProgramme.vaccinationRecord.dose.number", {
          sequence: valid.sequence
        })
      },
      {
        header: __("vaccination.createdAt.label"),
        text: valid.vaccination.formatted.createdAt_date
      }
    ]) %}
  {% endfor %}

  {% for sequence in range(summary.validDoses.length + 1, summary.dosesNeeded + 1) %}
    {% set rows = rows | push([
      {
        header: __("patientProgramme.vaccinationRecord.dose.label"),
        text: __mf("patientProgramme.vaccinationRecord.dose.number", {
          sequence: sequence
        })
      },
      {
        header: __("vaccination.createdAt.label"),
        text: "—"
      }
    ]) %}
  {% endfor %}

  {{ table({
    id: "vaccination-record",
    responsive: true,
    head: [
      { text: __("patientProgramme.vaccinationRecord.dose.label") },
      { text: __("vaccination.createdAt.label") }
    ],
    rows: rows
  }) if rows.length }}
{% endcall %}
