{% from "_macros/patient-search.njk" import appPatientSearch with context %}

{% extends "_layouts/session.njk" %}

{% set title = session.shortName + " – " + __("session." + view + ".title") %}
{% set heading = session.shortName %}
{% set caption = session.formatted.date
   + (" – " + session.formatted.yearGroups if session.type === SessionType.School)
%}

{% block content %}
  {% if (view == "record") and not session.isActive %}
    {{ appHeading({
      level: 2,
      size: "m",
      title: __("session." + view + ".title"),
      summary: __("session." + view + ".information") | safe
    }) }}
  {% else %}
    <div class="nhsuk-grid-row">
      <app-auto-submit class="app-grid-column-filters">
        {{ appPatientSearch({
          clear: session.uri + "/" + view,
          checkboxFilters: checkboxFilters,
          radioFilters: radioFilters,
          hideClinicStatuses: true,
          view: view
        }) }}
      </app-auto-submit>

      <div class="app-grid-column-results">
        {{ details({
          classes: "nhsuk-expander app-expander--compact nhsuk-u-margin-top-3",
          summaryText: "Your vaccinations today",
          html: table({
            responsive: true,
            firstCellIsHeader: false,
            head: [
              { text: __("vaccine.label") },
              { text: __("user.vaccinations.label") },
              { text: __("defaultBatch.label") }
            ],
            rows: vaccinationTableRows(session)
          }) if view == "record"
        }) if view == "record" and session.isActive }}

        {% if data[view] and data[view] != "none" %}
          {% set title = __("patientSession." + view + ".label") + ": " + data[view] %}
        {% else %}
          {% set title = __("session." + view + ".title") %}
        {% endif %}

        {{ appHeading({
          level: 3,
          size: "m",
          title: title | replace(",", " or "),
          summary: __mf("patient.results.summary", {
            from: results.from,
            to: results.to,
            count: results.count
          }) | safe
        }) }}

        {% if view == "instruct" and session.activity.instruct and account.canPrescribe %}
          {% call insetText() %}
            {{ __("session.instruct.description", session.activity.instruct) | nhsukMarkdown }}

            {{ actionLink({
              text: __("session.instructions.label"),
              href: session.uri + "/instructions"
            }) }}
          {% endcall %}
        {% endif %}

        {% for patientSession in results.page %}
          {% set reportStatusHtml %}
            {% set ids = data.programme_id or session.programme_ids %}
            {% for patientSession in patientSession.siblingPatientSessions %}
              {% if ids | includes(patientSession.programme_id) %}
                {{ patientSession.formatted.report | nhsukMarkdown }}
              {% endif %}
            {% endfor %}
          {% endset %}

          {% call card({
            classes: "app-card--compact",
            heading: patientSession.patient.fullAndPreferredNames | highlightQuery(data.q),
            headingSize: "s",
            headingLevel: 4,
            clickable: not showRegistration,
            href: patientSession.uri
          }) %}
            {{ summaryList({
              rows: summaryRows(patientSession.patient, {
                dob: {},
                impairments: {},
                adjustments: {},
                yearGroup: {
                  value: patientSession.formatted.yearGroup
                },
                vaccineCriteria: {
                  label: __("patientSession.vaccineCriteria.label"),
                  value: patientSession.formatted.vaccineCriteria
                } if session.offersAlternativeVaccine,
                instruct: {
                  label: __("patientSession.instruct.label"),
                  value: patientSession.formatted.instruct
                } if patientSession.instruct,
                register: {
                  label: __("patientSession.register.label"),
                  value: patientSession.formatted.register,
                  href: (patientSession.uri + "/edit/registration?referrer=" + session.uri + "/" + view) if view == "register" and patientSession.register != RegistrationOutcome.Pending
                } if showRegistration,
                report: {
                  label: __("patientSession.report.label"),
                  value: reportStatusHtml
                },
                notes: {
                  label: __("patientSession.pinnedNote.label"),
                  value: appEvent({
                    auditEvent: patientSession.pinnedNotes[0],
                    showProgrammes: false,
                    truncate: 300,
                    patientSession: patientSession
                  })
                } if patientSession.pinnedNotes[0]
              })
            }) }}

            {{ appButtonGroup({
              buttons: [{
                text: __("patientSession.registration.actions.present.label"),
                small: true,
                variant: "secondary",
                decorate: "patientSession.register",
                value: RegistrationOutcome.Present,
                attributes: {
                  "aria-label": __("patientSession.registration.actions.present.title", { patient: patientSession.patient }),
                  formaction: patientSession.uri + "/edit/registration?referrer=" + session.uri + "/" + view + "&register=" + data.register,
                  formmethod: "post"
                }
              }, {
                classes: "app-button--secondary-warning",
                text: __("patientSession.registration.actions.absent.label"),
                small: true,
                decorate: "patientSession.register",
                value: RegistrationOutcome.Absent,
                attributes: {
                  "aria-label": __("patientSession.registration.actions.absent.title", { patient: patientSession.patient }),
                  formaction: patientSession.uri + "/edit/registration?referrer=" + session.uri + "/" + view + "&register=" + data.register,
                  formmethod: "post"
                }
              }]
            }) if showRegistration and patientSession.register == RegistrationOutcome.Pending }}
          {% endcall %}
        {% endfor %}

        {{ pagination(pages) }}
      </div>
    </div>
  {% endif %}
{% endblock %}
