{% extends "_layouts/session.njk" %}

{% set title = session.shortName %}
{% set heading = title %}
{% set caption = session.formatted.date
   + (" – " + session.formatted.yearGroups if session.type === SessionType.School)
%}

{% block content %}
  {{ warningCallout({
    heading: __("consent.title"),
    html: link(session.uri + "/consents", __mf("consent.count", {
      count: session.consents.length
    })) | nhsukMarkdown
  }) if session.consents.length }}

  {% include "session/_session-programme-summary.njk" %}

  {% if session.isActive or session.isCompleted %}
    {% include "session/_session-vaccinated-summary.njk" %}
  {% endif %}

  {% if not session.isUnplanned %}
    {% include "session/_session-activity-summary.njk" %}
  {% endif %}

  {% if session.type === SessionType.Clinic %}
    {% set sessionAvailabilityRows = appointmentAvailabilityRows(session) %}
    {{ summaryList({
      card: {
        heading: __("session.appointments.available.label"),
        headingLevel: 3
      },
      rows: sessionAvailabilityRows
    }) if sessionAvailabilityRows.length > 0 }}
  {% endif %}

  {% call card({
    heading: __("session.summary"),
    headingLevel: 3,
    actions: {
      items: [
      {
        text: __("session.schedule.title") if session.isUnplanned else __("session.edit.title"),
        href: session.uri + "/edit"
      },
      {
        text: __("session.action.cancel"),
        href: session.uri + "/cancel"
      } if session.isPlanned or session.isUnplanned
      ]
    }
  }) %}
    {% set sessionDetailsRows = {
      location: {},
      school_id: {},
      status: {},
      patients: {},
      programmes: {},
      yearGroups: {},
      consentWindow: {},
      consentForms: {},
      mmrConsent: {}
    } %}
    {% if session.type === SessionType.Clinic %}
      {% set sessionDetailsRows = {
          location: {},
          status: {},
          programmes: {},
          date: {},
          vaccinationPeriods: {},
          vaccinators: {},
          appointmentLength: {}
      } %}
    {% endif %}

    {{ summaryList({
      rows: summaryRows(session, sessionDetailsRows)
    }) }}

    {{ actionLink({
      text: __("session.download.label"),
      href: session.uri + "/download?referrer=" + session.uri
    }) if session.isPlanned or session.isActive }}
  {% endcall %}
{% endblock %}
