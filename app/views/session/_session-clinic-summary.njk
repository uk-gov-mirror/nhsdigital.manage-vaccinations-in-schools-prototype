{{ appHeading({
  title: "Appointments",
  level: 3,
  size: "m"
}) }}

<div class="nhsuk-grid-row nhsuk-card-group">
  {% set columnWidth = "quarter" %}

  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: __("session.tally.appointments.total.label"),
      headingLevel: 4,
      compact: true,
      data: session.totalAppointmentCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: __("session.tally.appointments.available.label"),
      headingLevel: 4,
      colour: "white" if session.availableAppointmentCount > 10 else ("orange" if session.availableAppointmentCount > 0 else "red"),
      compact: true,
      data: session.availableAppointmentCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: __("session.tally.vaccinators.maximum.label") if session.hasVariableVaccinatorCounts else __("session.tally.vaccinators.consistent.label"),
      headingLevel: 4,
      compact: true,
      data: session.maximumVaccinatorCount,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: __("session.tally.appointments.daysLeft.label"),
      headingLevel: 4,
      colour: "orange" if session.daysLeftToBook < 7 and session.daysLeftToBook > 0,
      compact: true,
      data: session.daysLeftToBook,
      href: session.uri + "/edit"
    }) }}
  </div>
  <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
    {{ appDataCard({
      heading: __("session.tally.appointments.unmatched.label"),
      headingLevel: 4,
      colour: "orange" if session.unmatchedAppointments.length > 0,
      compact: true,
      data: session.unmatchedAppointments.length,
      href: session.uri + "/appointments"
    }) }}
  </div>
  {% for programme in session.programmes %}
    <div class="nhsuk-grid-column-one-{{ columnWidth }} nhsuk-card-group__item">
      {{ appDataCard({
        heading: __("session.tally.appointments.programmeRequests.label", programme.type),
        headingLevel: 4,
        colour: "green",
        compact: true,
        data: "0",
        href: session.uri + "/report?programme_id=" + programme.id
      }) }}
    </div>
  {% endfor %}
</div>
