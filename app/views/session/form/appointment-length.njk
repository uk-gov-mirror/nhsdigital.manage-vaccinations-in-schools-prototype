{% extends "_layouts/form.njk" %}

{% set title = __("session.appointmentLength.title") %}

{% block form %}
  {{ input({
    label: {
      isPageHeading: true,
      text: title,
      size: "l"
    },
    suffix: __("session.appointmentLength.suffix"),
    width: 2,
    inputmode: "numeric",
    spellcheck: false,
    decorate: "session.appointmentLength"
  }) }}
{% endblock %}
